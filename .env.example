NODE_ENV=production
PORT=4173
PUBLIC_SITE_URL=https://www.cpmanagementgroup.co.uk

# Lead storage
# Supported: jsonl, supabase, airtable, webhook
LEAD_STORAGE_PROVIDER=supabase
LEAD_BACKUP_JSONL=true
DATA_DIR=./data
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CONTACT_TABLE=contact_enquiries
SUPABASE_BOOKING_TABLE=booking_leads
SUPABASE_CAREERS_TABLE=career_applications
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_CONTACT_TABLE=contact_enquiries
AIRTABLE_BOOKING_TABLE=booking_leads
AIRTABLE_CAREERS_TABLE=career_applications
LEAD_WEBHOOK_URL=

# Email notifications
# Supported: none, resend, sendgrid, mailgun, smtp
EMAIL_PROVIDER=resend
EMAIL_FROM=CPMG <no-reply@cpmanagementgroup.co.uk>
EMAIL_TO=info@cpmanagementgroup.co.uk
RESEND_API_KEY=
SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_HELO=cpmanagementgroup.co.uk

# Careers CV upload
# Supported: local, s3
CV_STORAGE_PROVIDER=s3
CV_MAX_BYTES=5242880
PRIVATE_UPLOAD_DIR=./private_uploads
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Admin visibility
ADMIN_TOKEN=
